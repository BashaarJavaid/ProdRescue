# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prodrescue

# ── Messaging / cache ───────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
REDIS_URL=redis://localhost:6379/0

# ── LLM (Xiaomi MiMo-V2.5-Pro via OpenAI-compatible endpoint) ───
# Provider-agnostic: point these at any OpenAI-compatible server.
LLM_BASE_URL=https://api.example-mimo.com/v1
LLM_API_KEY=changeme
LLM_MODEL=MiMo-V2.5-Pro

# ── Embeddings ──────────────────────────────────────────────────
# EMBED_BACKEND: "sentence-transformers" (real) or "hash" (deterministic, no deps — for tests)
EMBED_BACKEND=sentence-transformers
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# ── GitHub ──────────────────────────────────────────────────────
# Leave GITHUB_TOKEN empty to use the dry-run PR fallback (writes artifacts to dryrun_prs/).
GITHUB_TOKEN=
REPO_FULL_NAME=youruser/prodrescue-sample-target

# ── Custom MCP servers ──────────────────────────────────────────
HARNESS_MCP_URL=http://localhost:8001/mcp
LOGS_DB_MCP_URL=http://localhost:8002/mcp

# ── Observability (optional) ────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=prodrescue
LANGCHAIN_TRACING_V2=false
WORKER_METRICS_PORT=9100
